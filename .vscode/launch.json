{
    "version": "0.2.0",
    "configurations": [
        {
            "name": ".NET Launch galaxy-football-server",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "Build galaxy-football-backend.sln",
            "program": "${workspaceFolder}/src/galaxy-football-server/bin/Debug/net8.0/galaxy-football-server.dll",
            "args": [],
            "cwd": "${workspaceFolder}/src/galaxy-football-server",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "Now listening on: (https?://\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            },
            "sourceFileMap": {
                "/Views": "${workspaceFolder}/src/galaxy-football-server/Views"
            }
        }
    ]
}
